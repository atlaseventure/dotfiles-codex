# 按当前账户可用模型调整。
model = "gpt-5.6-sol"
model_reasoning_effort = "high"
disable_response_storage = true
personality = "pragmatic"

[windows]
sandbox = "unelevated"

[model_providers.custom]
name = "custom"
wire_api = "responses"
requires_openai_auth = true
# supports_websockets = true
base_url = "https://api.openai.com/v1"

